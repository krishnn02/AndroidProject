<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<style>
  @import url('https://fonts.googleapis.com/css2?family=Merriweather:wght@300;400;700;900&family=Source+Sans+3:wght@300;400;600;700&display=swap');

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Source Sans 3', -apple-system, sans-serif;
    color: #1a1a1a;
    line-height: 1.7;
    font-size: 11pt;
    background: white;
  }

  /* ===== FRONT PAGE ===== */
  .front-page {
    page-break-after: always;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 50px 60px;
    text-align: center;
  }

  /* Top row logos */
  .logo-top-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 30px;
    margin-bottom: 20px;
    width: 100%;
  }

  .logo-top-row img {
    object-fit: contain;
  }

  /* Main event logo — last logo */
  .main-event-logo {
    text-align: center;
    margin-bottom: 16px;
  }

  .main-event-logo img {
    max-width: 240px;
    max-height: 160px;
    object-fit: contain;
  }

  .institution-name {
    font-family: 'Merriweather', serif;
    font-size: 16pt;
    font-weight: 900;
    color: #c0392b;
    letter-spacing: 0.5px;
    margin-bottom: 4px;
  }

  .department-name {
    font-size: 12pt;
    font-weight: 700;
    color: #2c3e50;
    margin-bottom: 8px;
  }

  .report-label {
    font-size: 11pt;
    color: #555;
    margin-bottom: 6px;
  }

  .event-title {
    font-family: 'Merriweather', serif;
    font-size: 18pt;
    font-weight: 900;
    color: #1a1a1a;
    margin-bottom: 6px;
    line-height: 1.3;
  }

  .event-subtitle {
    font-size: 12pt;
    color: #555;
    margin-bottom: 24px;
  }

  /* Event details table — formal bordered style like report1 */
  .details-table {
    width: 90%;
    border-collapse: collapse;
    margin: 20px auto;
    border: 1px solid #333;
  }

  .details-table td {
    padding: 8px 14px;
    font-size: 10pt;
    border: 1px solid #333;
    vertical-align: top;
  }

  .detail-key {
    font-weight: 700;
    color: #c0392b;
    width: 35%;
  }

  .detail-value {
    color: #1a1a1a;
  }

  /* ===== CONTENT SECTIONS ===== */
  .content-card {
    background: white;
    border: 1px solid #e0e0e0;
    border-radius: 12px;
    padding: 20px 24px;
    margin: 16px 30px;
    page-break-inside: avoid;
  }

  .section-heading {
    font-family: 'Merriweather', serif;
    font-size: 14pt;
    font-weight: 700;
    color: #c0392b;
    margin-bottom: 12px;
    padding-bottom: 6px;
    border-bottom: 2px solid #f0f0f0;
  }

  .section-content p {
    text-align: justify;
    margin-bottom: 10px;
    color: #333;
    font-size: 10.5pt;
  }

  .section-content ul {
    margin-left: 24px;
    margin-bottom: 12px;
  }

  .section-content ul li {
    margin-bottom: 6px;
    color: #333;
  }

  .section-content ul li::marker {
    color: #c0392b;
  }

  /* ===== IMAGE RECTANGLES ===== */
  .image-rectangle {
    border: 1px solid #ddd;
    border-radius: 8px;
    padding: 8px;
    margin: 12px 30px;
    text-align: center;
    page-break-inside: avoid;
  }

  .image-rectangle img {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: 4px;
  }

  .img-caption {
    text-align: center;
    font-size: 8pt;
    color: #999;
    margin-top: 4px;
    font-style: italic;
  }

  /* ===== IMAGE GRID LAYOUTS (in sections) ===== */
  .image-container { margin: 16px 0; }
  .img-full { text-align: center; }
  .img-full img { width: 100%; max-height: 400px; object-fit: cover; border-radius: 4px; }
  .img-side-by-side { display: flex; gap: 12px; }
  .img-side-by-side img { flex: 1; width: 48%; height: 240px; object-fit: cover; border-radius: 4px; }
  .img-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(45%, 1fr)); gap: 12px; }
  .img-grid img { width: 100%; height: 200px; object-fit: cover; border-radius: 4px; }

  /* ===== BUDGET TABLE ===== */
  .budget-table { width: 100%; border-collapse: collapse; margin: 14px 0; font-size: 10pt; }
  .budget-table th {
    background: #c0392b; color: white; padding: 10px 14px;
    text-align: left; font-weight: 600; font-size: 9pt;
    text-transform: uppercase; letter-spacing: 0.5px;
  }
  .budget-table td { padding: 9px 14px; border-bottom: 1px solid #eee; }
  .budget-table tr:nth-child(even) { background: #fafafa; }
  .budget-total { font-weight: 700; background: #f5f5f5 !important; color: #c0392b; }

  /* ===== GALLERY ===== */
  .gallery-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin: 14px 0; }
  .gallery-grid img { width: 100%; height: 180px; object-fit: cover; border-radius: 4px; }

  /* ===== FOOTER ===== */
  .report-footer {
    text-align: left;
    margin: 30px 30px;
    padding-top: 12px;
    border-top: 1px solid #ddd;
    font-size: 10pt;
    color: #555;
  }

  @media print {
    .content-card { page-break-inside: avoid; }
    .front-page { page-break-after: always; }
  }
</style>
</head>
<body>

  <!-- FRONT PAGE -->
  <div class="front-page">

    <!-- Top row logos (all except the last) -->
    {{#if report.frontPage.logos.length}}
      <div class="logo-top-row">
        {{#each report.frontPage.logos}}
          {{#unless @last}}
            <img src="{{this}}" alt="Logo" style="width: {{logoSize ../report.frontPage.logos.length}}px; height: {{logoSize ../report.frontPage.logos.length}}px;">
          {{/unless}}
        {{/each}}
      </div>
    {{/if}}

    {{#if report.frontPage.institutionName}}
      <div class="institution-name">{{report.frontPage.institutionName}}</div>
    {{/if}}
    {{#if report.frontPage.departmentName}}
      <div class="department-name">{{report.frontPage.departmentName}}</div>
    {{/if}}

    <div class="report-label">Activity Report of</div>

    <!-- Main event logo (last one) — centered and larger -->
    {{#if report.frontPage.logos.length}}
      <div class="main-event-logo">
        <img src="{{lastLogo report.frontPage.logos}}" alt="Event Banner">
      </div>
    {{/if}}

    <!-- Title -->
    <div class="event-title">{{report.frontPage.eventTitle}}</div>
    {{#if report.frontPage.eventSubtitle}}
      <div class="event-subtitle">{{report.frontPage.eventSubtitle}}</div>
    {{/if}}

    <!-- Event Details Table — bordered like report1.pdf -->
    {{#if report.frontPage.eventDetails.length}}
      <table class="details-table">
        {{#each report.frontPage.eventDetails}}
          <tr>
            <td class="detail-key">{{this.key}}</td>
            <td class="detail-value">{{this.value}}</td>
          </tr>
        {{/each}}
      </table>
    {{/if}}
  </div>

  <!-- CONTENT SECTIONS (each in its own curved-edge card) -->
  {{#each sections}}
    {{#unless (eq this.type "BUDGET")}}
      {{#unless (eq this.type "GALLERY")}}
        <div class="content-card">
          <h2 class="section-heading">{{this.heading}}</h2>
          <div class="section-content">
            {{#each this.content.paragraphs}}<p>{{this}}</p>{{/each}}
            {{#if this.content.bullets.length}}
              <ul>{{#each this.content.bullets}}<li>{{this}}</li>{{/each}}</ul>
            {{/if}}
            {{#if this.content.richText}}{{{this.content.richText}}}{{/if}}
          </div>
          {{#if this.images.length}}
            <div class="image-container {{imageGridClass this.imageCount}}">
              {{#each this.images}}
                <div><img src="{{this.url}}" alt="{{this.caption}}">{{#if this.caption}}<div class="img-caption">{{this.caption}}</div>{{/if}}</div>
              {{/each}}
            </div>
          {{/if}}
        </div>
      {{/unless}}
    {{/unless}}
  {{/each}}

  <!-- GALLERY SECTIONS — images in individual rectangles -->
  {{#each sections}}
    {{#if (eq this.type "GALLERY")}}
      <div class="content-card">
        <h2 class="section-heading">{{this.heading}}</h2>
      </div>
      {{#each this.images}}
        <div class="image-rectangle">
          <img src="{{this.url}}" alt="{{this.caption}}">
          {{#if this.caption}}<div class="img-caption">{{this.caption}}</div>{{/if}}
        </div>
      {{/each}}
    {{/if}}
  {{/each}}

  <!-- BUDGET SECTION -->
  {{#if budgets.length}}
    <div class="content-card">
      <h2 class="section-heading">Budget Summary</h2>
      <table class="budget-table">
        <thead><tr><th>#</th><th>Item</th><th>Category</th><th>Qty</th><th>Unit Cost</th><th>Total</th></tr></thead>
        <tbody>
          {{#each budgets}}
            <tr><td>{{@index}}</td><td>{{this.item}}</td><td>{{this.category}}</td><td>{{this.quantity}}</td><td>{{formatCurrency this.unitCost}}</td><td>{{formatCurrency this.totalCost}}</td></tr>
          {{/each}}
          <tr class="budget-total"><td colspan="5" style="text-align:right;"><strong>Grand Total</strong></td><td><strong>{{formatCurrency budgetTotal}}</strong></td></tr>
        </tbody>
      </table>
    </div>
  {{/if}}

  <div class="report-footer">
    Report Prepared By: {{report.createdBy.name}}<br>
    <span style="font-size:8pt;color:#999;">Generated on {{generatedAt}} | Smart Event Report System</span>
  </div>

</body>
</html>
