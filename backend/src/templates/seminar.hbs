<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800&family=Source+Sans+3:wght@300;400;500;600;700&display=swap');

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Source Sans 3', -apple-system, sans-serif;
    color: #1e293b;
    line-height: 1.8;
    font-size: 11pt;
  }

  /* ===== FRONT PAGE ===== */
  .front-page {
    page-break-after: always;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: linear-gradient(170deg, #fffbeb 0%, #fef3c7 30%, #f5f3ff 60%, #faf5ff 100%);
    padding: 40px 50px;
    position: relative;
  }

  .front-page::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 6px;
    background: linear-gradient(90deg, #1e3a5f, #b8860b, #1e3a5f);
  }

  .front-page::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, #b8860b, transparent);
  }

  .logo-row {
    display: flex; align-items: center; justify-content: center;
    gap: 28px; margin-bottom: 30px;
  }

  .logo-row img {
    width: 72px; height: 72px; object-fit: contain; border-radius: 4px;
    box-shadow: 0 4px 16px rgba(30,58,95,0.1);
    border: 1px solid rgba(184,134,11,0.2);
  }

  .institution-name {
    font-size: 20pt; font-weight: 800; color: #1e3a5f;
    letter-spacing: 2px; text-transform: uppercase; margin-bottom: 4px;
    font-family: 'Playfair Display', serif;
  }

  .department-name {
    font-size: 13pt; font-weight: 600; color: #b8860b; margin-bottom: 30px;
    letter-spacing: 1px;
  }

  .hero-banner {
    width: 80%; max-height: 240px; object-fit: cover; border-radius: 4px;
    margin-bottom: 30px;
    box-shadow: 0 8px 32px rgba(30,58,95,0.12);
    border: 2px solid rgba(184,134,11,0.15);
  }

  .event-title {
    font-size: 28pt; font-weight: 700; color: #1e3a5f;
    margin-bottom: 8px; line-height: 1.2;
    font-family: 'Playfair Display', serif;
  }

  .event-subtitle {
    font-size: 14pt; font-weight: 400; color: #64748b; margin-bottom: 24px;
    font-style: italic;
  }

  .event-meta {
    display: flex; justify-content: center; gap: 28px; margin-bottom: 28px; flex-wrap: wrap;
  }

  .meta-item {
    background: white; padding: 12px 24px; border-radius: 2px;
    box-shadow: 0 1px 6px rgba(0,0,0,0.04); font-size: 10pt;
    border-bottom: 2px solid #b8860b;
  }

  .meta-item strong { color: #b8860b; display: block; font-size: 7pt; text-transform: uppercase; letter-spacing: 1.5px; }

  .coordinators-section { margin-top: 24px; width: 80%; }

  .coordinators-section h3 {
    font-size: 10pt; text-transform: uppercase; letter-spacing: 2px; color: #1e3a5f; margin-bottom: 12px;
    font-family: 'Playfair Display', serif;
  }

  .coord-grid { display: flex; justify-content: center; gap: 18px; flex-wrap: wrap; }

  .coord-item {
    background: white; padding: 10px 20px; border-radius: 2px;
    font-size: 9pt; box-shadow: 0 1px 4px rgba(0,0,0,0.04);
    border-left: 2px solid #b8860b;
  }

  .coord-item .label { font-size: 7pt; color: #b8860b; text-transform: uppercase; letter-spacing: 1px; }
  .coord-item .name { font-weight: 600; color: #1e3a5f; }

  /* ===== CONTENT PAGES ===== */
  .section { margin-bottom: 30px; page-break-inside: avoid; }

  .section-heading {
    font-size: 17pt; font-weight: 700; color: #1e3a5f;
    border-bottom: 2px solid #b8860b; padding-bottom: 6px;
    margin-bottom: 16px;
    font-family: 'Playfair Display', serif;
  }

  .section-content p { text-align: justify; margin-bottom: 10px; color: #334155; }
  .section-content ul { margin-left: 20px; margin-bottom: 12px; }
  .section-content ul li { margin-bottom: 6px; color: #334155; }
  .section-content ul li::marker { color: #b8860b; }

  /* ===== IMAGE LAYOUTS ===== */
  .image-container { margin: 16px 0; }
  .img-full { text-align: center; }
  .img-full img { width: 100%; max-height: 400px; object-fit: cover; border-radius: 4px; border: 1px solid #e2e8f0; }
  .img-side-by-side { display: flex; gap: 14px; }
  .img-side-by-side img { flex: 1; width: 48%; height: 240px; object-fit: cover; border-radius: 4px; border: 1px solid #e2e8f0; }
  .img-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(45%, 1fr)); gap: 14px; }
  .img-grid img { width: 100%; height: 200px; object-fit: cover; border-radius: 4px; border: 1px solid #e2e8f0; }

  .frame-circle img { border-radius: 50%; aspect-ratio: 1; }
  .frame-oval img { border-radius: 50%; }
  .frame-rounded img { border-radius: 8px; }

  .img-caption { text-align: center; font-size: 8pt; color: #94a3b8; margin-top: 4px; font-style: italic; }

  /* ===== BUDGET TABLE ===== */
  .budget-table { width: 100%; border-collapse: collapse; margin: 14px 0; font-size: 10pt; }
  .budget-table th {
    background: #1e3a5f;
    color: white; padding: 11px 14px; text-align: left; font-weight: 600;
    font-size: 9pt; text-transform: uppercase; letter-spacing: 1px;
  }
  .budget-table td { padding: 9px 14px; border-bottom: 1px solid #e2e8f0; }
  .budget-table tr:nth-child(even) { background: #fafaf5; }
  .budget-total { font-weight: 700; background: #fef3c7 !important; color: #92400e; }

  /* ===== GALLERY ===== */
  .gallery-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin: 14px 0; }
  .gallery-grid img { width: 100%; height: 180px; object-fit: cover; border-radius: 4px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); border: 1px solid #e2e8f0; }

  @media print {
    .section { page-break-inside: avoid; }
    .front-page { page-break-after: always; }
  }
</style>
</head>
<body>

  <div class="front-page">
    <div class="logo-row">
      {{#if report.frontPage.collegeLogo}}<img src="{{report.frontPage.collegeLogo}}" alt="College">{{/if}}
      {{#if report.frontPage.departmentLogo}}<img src="{{report.frontPage.departmentLogo}}" alt="Department">{{/if}}
      {{#if report.frontPage.eventLogo}}<img src="{{report.frontPage.eventLogo}}" alt="Event">{{/if}}
    </div>

    <div class="institution-name">{{report.frontPage.institutionName}}</div>
    <div class="department-name">{{report.frontPage.departmentName}}</div>

    {{#if report.frontPage.heroBanner}}<img src="{{report.frontPage.heroBanner}}" class="hero-banner" alt="Event Banner">{{/if}}

    <div class="event-title">{{report.frontPage.eventTitle}}</div>
    {{#if report.frontPage.eventSubtitle}}<div class="event-subtitle">{{report.frontPage.eventSubtitle}}</div>{{/if}}

    <div class="event-meta">
      {{#if report.frontPage.venueDate}}<div class="meta-item"><strong>Date</strong>{{report.frontPage.venueDate}}</div>{{/if}}
      {{#if report.event.venue}}<div class="meta-item"><strong>Venue</strong>{{report.event.venue}}</div>{{/if}}
      {{#if report.event.department}}<div class="meta-item"><strong>Department</strong>{{report.event.department}}</div>{{/if}}
    </div>

    <div class="coordinators-section">
      <h3>Organized By</h3>
      <div class="coord-grid">
        {{#if report.event.convener}}<div class="coord-item"><div class="label">Convener</div><div class="name">{{report.event.convener}}</div></div>{{/if}}
        {{#if report.event.coConvener}}<div class="coord-item"><div class="label">Co-Convener</div><div class="name">{{report.event.coConvener}}</div></div>{{/if}}
        {{#if report.event.facultyCoordinator}}<div class="coord-item"><div class="label">Faculty Coordinator</div><div class="name">{{report.event.facultyCoordinator}}</div></div>{{/if}}
        {{#if report.event.studentCoordinator}}<div class="coord-item"><div class="label">Student Coordinator</div><div class="name">{{report.event.studentCoordinator}}</div></div>{{/if}}
      </div>
    </div>
  </div>

  {{#each sections}}
    {{#unless (eq this.type "BUDGET")}}
      {{#unless (eq this.type "GALLERY")}}
        <div class="section">
          <h2 class="section-heading">{{this.heading}}</h2>
          <div class="section-content">
            {{#each this.content.paragraphs}}<p>{{this}}</p>{{/each}}
            {{#if this.content.bullets.length}}<ul>{{#each this.content.bullets}}<li>{{this}}</li>{{/each}}</ul>{{/if}}
            {{#if this.content.richText}}{{{this.content.richText}}}{{/if}}
          </div>
          {{#if this.images.length}}
            <div class="image-container {{imageGridClass this.imageCount}} frame-{{this.imageFrame}}">
              {{#each this.images}}<div><img src="{{this.url}}" alt="{{this.caption}}">{{#if this.caption}}<div class="img-caption">{{this.caption}}</div>{{/if}}</div>{{/each}}
            </div>
          {{/if}}
        </div>
      {{/unless}}
    {{/unless}}
  {{/each}}

  {{#each sections}}
    {{#if (eq this.type "GALLERY")}}
      <div class="section">
        <h2 class="section-heading">{{this.heading}}</h2>
        <div class="gallery-grid">{{#each this.images}}<img src="{{this.url}}" alt="{{this.caption}}">{{/each}}</div>
      </div>
    {{/if}}
  {{/each}}

  {{#if budgets.length}}
    <div class="section">
      <h2 class="section-heading">Budget Summary</h2>
      <table class="budget-table">
        <thead><tr><th>#</th><th>Item</th><th>Category</th><th>Qty</th><th>Unit Cost</th><th>Total</th></tr></thead>
        <tbody>
          {{#each budgets}}<tr><td>{{@index}}</td><td>{{this.item}}</td><td>{{this.category}}</td><td>{{this.quantity}}</td><td>{{formatCurrency this.unitCost}}</td><td>{{formatCurrency this.totalCost}}</td></tr>{{/each}}
          <tr class="budget-total"><td colspan="5" style="text-align:right;"><strong>Grand Total</strong></td><td><strong>{{formatCurrency budgetTotal}}</strong></td></tr>
        </tbody>
      </table>
    </div>
  {{/if}}

  <div style="text-align:center;margin-top:40px;padding:20px;border-top:2px solid #b8860b;font-size:8pt;color:#94a3b8;">
    Report generated on {{generatedAt}} | Smart Event Report System
  </div>

</body>
</html>
