<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<style>
  @import url('https://fonts.googleapis.com/css2?family=Merriweather:ital,wght@0,300;0,400;0,700;0,900;1,300&family=Source+Sans+3:wght@300;400;500;600;700;800&display=swap');

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Source Sans 3', -apple-system, sans-serif;
    color: #1e293b;
    line-height: 1.6;
    font-size: 11pt;
    background: #ffffff;
  }

  /* ===== FRONT PAGE ===== */
  .front-page {
    page-break-after: always;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 35px 25px;
    border: 2px solid #cbd5e1;
    border-radius: 12px;
    background: linear-gradient(180deg, #fafaf9 0%, #f5f5f4 100%);
    position: relative;
  }

  /* Top Accent Line */
  .front-page::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 10px;
    background: linear-gradient(90deg, #800000 0%, #475569 100%);
    border-top-left-radius: 10px;
    border-top-right-radius: 10px;
  }

  .logo-top-row {
    display: flex; align-items: center; justify-content: center;
    flex-wrap: nowrap; gap: 20px; margin-bottom: 35px; width: 100%;
  }

  .logo-top-row img {
    height: 48px;
    max-width: 80px;
    object-fit: contain;
    margin: 0 8px;
  }

  .main-event-logo { text-align: center; margin-bottom: 30px; }
  .main-event-logo img {
    height: 130px;
    max-width: 320px;
    object-fit: contain;
  }

  .institution-name { font-family: 'Merriweather', serif; font-size: 15pt; font-weight: 900; color: #800000; letter-spacing: 0.5px; text-transform: uppercase; margin-bottom: 6px; }
  .department-name { font-size: 11pt; font-weight: 600; color: #475569; text-transform: uppercase; margin-bottom: 30px; }

  .event-title { font-family: 'Merriweather', serif; font-size: 20pt; font-weight: 900; color: #0f172a; margin-bottom: 8px; line-height: 1.3; }
  .event-subtitle { font-size: 12pt; font-weight: 400; color: #475569; margin-bottom: 35px; max-width: 90%; }

  .details-table {
    width: 95%; border-collapse: collapse; margin: 15px auto;
    background: rgba(255, 255, 255, 0.65); border-radius: 8px; overflow: hidden;
    border: 1px solid #cbd5e1;
  }
  .details-table td { padding: 10px 15px; font-size: 9.5pt; border-bottom: 1px solid #cbd5e1; text-align: left; }
  .details-table tr:last-child td { border-bottom: none; }
  .detail-key { font-weight: 700; color: #800000; width: 35%; background: #fef2f2; }
  .detail-value { color: #334155; }

  /* ===== CONTENT ===== */
  .content-card {
    background: #ffffff;
    padding: 15px 0;
    margin: 15px 0;
    page-break-inside: avoid;
  }

  .section-heading { 
    font-family: 'Merriweather', serif;
    font-size: 13pt; 
    font-weight: 700; 
    color: #800000; 
    margin-bottom: 14px; 
    padding-bottom: 4px; 
    border-left: 4px solid #800000; 
    padding-left: 10px;
  }
  
  .section-content p { text-align: justify; margin-bottom: 12px; color: #334155; font-size: 10pt; }
  .section-content ul { margin-left: 20px; margin-bottom: 12px; }
  .section-content ul li { margin-bottom: 6px; color: #334155; font-size: 10pt; }
  .section-content ul li::marker { color: #800000; }

  .image-rectangle { 
    background: #ffffff; 
    border-radius: 8px; 
    padding: 8px; 
    margin: 15px 0; 
    border: 1px solid #cbd5e1; 
    text-align: center; 
    page-break-inside: avoid; 
  }
  .image-rectangle img { width: 100%; max-height: 380px; object-fit: cover; border-radius: 6px; }
  .img-caption { text-align: center; font-size: 8pt; color: #475569; margin-top: 6px; font-style: italic; }

  /* ===== IMAGE GRID LAYOUTS ===== */
  .section-grid {
    display: block;
  }
  .section-grid.has-images {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 20px;
    align-items: start;
  }
  .section-text { flex: 1; }
  .section-photos { flex: 1; }
  .image-container { display: grid; gap: 10px; width: 100%; }
  .img-full { grid-template-columns: 1fr; }
  .img-full img { width: 100%; max-height: 280px; object-fit: cover; border-radius: 8px; border: 1px solid #cbd5e1; }
  .img-side-by-side { grid-template-columns: 1fr 1fr; }
  .img-side-by-side img { width: 100%; height: 140px; object-fit: cover; border-radius: 8px; border: 1px solid #cbd5e1; }
  .img-grid { grid-template-columns: 1fr 1fr; }
  .img-grid img { width: 100%; height: 100px; object-fit: cover; border-radius: 6px; border: 1px solid #cbd5e1; }
  .image-wrapper { position: relative; }

  /* ===== BUDGET TABLE ===== */
  .budget-table { width: 100%; border-collapse: collapse; margin: 15px 0; font-size: 9.5pt; border: 1px solid #cbd5e1; border-radius: 8px; overflow: hidden; }
  .budget-table th { background: #800000; color: white; padding: 10px 12px; text-align: left; font-weight: 600; font-size: 8.5pt; text-transform: uppercase; }
  .budget-table td { padding: 8px 12px; border-bottom: 1px solid #cbd5e1; }
  .budget-table tr:nth-child(even) { background: #f8fafc; }
  .budget-total { font-weight: 700; background: #fef2f2 !important; color: #800000; }

  /* ===== GALLERY ===== */
  .gallery-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin: 15px 0; }
  .gallery-grid img { width: 100%; height: 150px; object-fit: cover; border-radius: 8px; border: 1px solid #cbd5e1; }

  /* ===== SIGNATURE CARD ===== */
  .signature-section {
    margin-top: 40px;
    padding-top: 20px;
    border-top: 2px dashed #cbd5e1;
    page-break-inside: avoid;
  }
  .sig-container {
    display: flex;
    justify-content: space-between;
    margin-top: 40px;
  }
  .sig-box {
    text-align: center;
    width: 30%;
  }
  .sig-line {
    border-top: 1px solid #800000;
    margin-bottom: 6px;
  }
  .sig-title {
    font-size: 9.5pt;
    font-weight: 600;
    color: #0f172a;
  }
  .sig-subtitle {
    font-size: 8pt;
    color: #475569;
  }

  .report-footer {
    text-align: center;
    margin-top: 50px;
    padding-top: 15px;
    border-top: 1px solid #cbd5e1;
    font-size: 8pt;
    color: #94a3b8;
  }

  @media print { 
    .content-card { page-break-inside: avoid; } 
    .front-page { page-break-after: always; } 
  }
</style>
</head>
<body>

  <!-- FRONT PAGE -->
  <div class="front-page">
    {{#if report.frontPage.logos.length}}
      <div class="logo-top-row">
        {{#each report.frontPage.logos}}
          {{#unless @last}}
            <img src="{{this}}" alt="Logo">
          {{/unless}}
        {{/each}}
      </div>
    {{/if}}

    {{#if report.frontPage.institutionName}}<div class="institution-name">{{report.frontPage.institutionName}}</div>{{/if}}
    {{#if report.frontPage.departmentName}}<div class="department-name">{{report.frontPage.departmentName}}</div>{{/if}}

    {{#if report.frontPage.logos.length}}
      <div class="main-event-logo"><img src="{{lastLogo report.frontPage.logos}}" alt="Event Logo"></div>
    {{/if}}

    <div class="event-title">{{report.frontPage.eventTitle}}</div>
    {{#if report.frontPage.eventSubtitle}}<div class="event-subtitle">{{report.frontPage.eventSubtitle}}</div>{{/if}}

    {{#if report.frontPage.eventDetails.length}}
      <table class="details-table">
        {{#each report.frontPage.eventDetails}}<tr><td class="detail-key">{{this.key}}</td><td class="detail-value">{{this.value}}</td></tr>{{/each}}
      </table>
    {{/if}}
  </div>

  <!-- CONTENT SECTIONS -->
  {{#each sections}}
    {{#unless (eq this.type "BUDGET")}}{{#unless (eq this.type "GALLERY")}}
      <div class="content-card">
        <h2 class="section-heading">{{this.heading}}</h2>
        <div class="section-grid {{#if this.images.length}}has-images{{/if}}">
          <div class="section-text">
            <div class="section-content">
              {{#each this.content.paragraphs}}<p>{{this}}</p>{{/each}}
              {{#if this.content.bullets.length}}<ul>{{#each this.content.bullets}}<li>{{this}}</li>{{/each}}</ul>{{/if}}
              {{#if this.content.richText}}{{{this.content.richText}}}{{/if}}
            </div>
          </div>
          {{#if this.images.length}}
            <div class="section-photos">
              <div class="image-container {{imageGridClass this.imageCount}}">
                {{#each this.images}}
                  <div class="image-wrapper">
                    <img src="{{this.url}}" alt="{{this.caption}}">
                    {{#if this.caption}}<div class="img-caption">{{this.caption}}</div>{{/if}}
                  </div>
                {{/each}}
              </div>
            </div>
          {{/if}}
        </div>
      </div>
    {{/unless}}{{/unless}}
  {{/each}}

  <!-- GALLERY SECTIONS -->
  {{#each sections}}
    {{#if (eq this.type "GALLERY")}}
      <div class="content-card">
        <h2 class="section-heading">{{this.heading}}</h2>
        <div class="gallery-grid">
          {{#each this.images}}
            <div class="image-wrapper">
              <img src="{{this.url}}" alt="{{this.caption}}">
              {{#if this.caption}}<div class="img-caption">{{this.caption}}</div>{{/if}}
            </div>
          {{/each}}
        </div>
      </div>
    {{/if}}
  {{/each}}

  <!-- BUDGET SUMMARY -->
  {{#if budgets.length}}
    <div class="content-card">
      <h2 class="section-heading">Budget Summary</h2>
      <table class="budget-table">
        <thead><tr><th style="width: 5%">#</th><th>Item</th><th>Category</th><th style="width: 10%">Qty</th><th style="width: 20%">Unit Cost</th><th style="width: 20%">Total</th></tr></thead>
        <tbody>
          {{#each budgets}}<tr><td>{{@index}}</td><td>{{this.item}}</td><td>{{this.category}}</td><td>{{this.quantity}}</td><td>{{formatCurrency this.unitCost}}</td><td>{{formatCurrency this.totalCost}}</td></tr>{{/each}}
          <tr class="budget-total"><td colspan="5" style="text-align:right;"><strong>Grand Total</strong></td><td><strong>{{formatCurrency budgetTotal}}</strong></td></tr>
        </tbody>
      </table>
    </div>
  {{/if}}

  <!-- SIGN-OFF SECTION -->
  <div class="signature-section">
    <div class="sig-container">
      <div class="sig-box">
        <div class="sig-line"></div>
        <div class="sig-title">{{report.createdBy.name}}</div>
        <div class="sig-subtitle">Report Prepared By<br>{{report.createdBy.department}}</div>
      </div>
      <div class="sig-box">
        <div class="sig-line"></div>
        <div class="sig-title">Coordinator</div>
        <div class="sig-subtitle">Event coordinator</div>
      </div>
      <div class="sig-box">
        <div class="sig-line"></div>
        <div class="sig-title">Head of Department</div>
        <div class="sig-subtitle">Department Head Approval</div>
      </div>
    </div>
  </div>

  <div class="report-footer">
    Report generated on {{generatedAt}} | Smart Event Report System
  </div>

</body>
</html>
