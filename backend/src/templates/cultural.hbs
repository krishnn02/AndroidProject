<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<style>
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap');

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Poppins', -apple-system, sans-serif;
    color: #2d1b4e;
    line-height: 1.7;
    font-size: 11pt;
  }

  /* ===== FRONT PAGE ===== */
  .front-page {
    page-break-after: always;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: linear-gradient(135deg, #fff5f5 0%, #ffe0cc 30%, #ffd6e8 60%, #f5e6ff 100%);
    padding: 40px 50px;
    position: relative;
    overflow: hidden;
  }

  .front-page::before {
    content: '';
    position: absolute;
    top: -50px; right: -50px;
    width: 200px; height: 200px;
    background: radial-gradient(circle, rgba(255,107,107,0.15) 0%, transparent 70%);
    border-radius: 50%;
  }

  .front-page::after {
    content: '';
    position: absolute;
    bottom: -60px; left: -60px;
    width: 250px; height: 250px;
    background: radial-gradient(circle, rgba(255,165,0,0.12) 0%, transparent 70%);
    border-radius: 50%;
  }

  .logo-row {
    display: flex; align-items: center; justify-content: center;
    gap: 24px; margin-bottom: 30px;
  }

  .logo-row img {
    width: 70px; height: 70px; object-fit: contain; border-radius: 12px;
    box-shadow: 0 4px 16px rgba(255,107,107,0.2);
  }

  .institution-name {
    font-size: 18pt; font-weight: 800; color: #c0392b;
    letter-spacing: 1px; text-transform: uppercase; margin-bottom: 4px;
  }

  .department-name {
    font-size: 13pt; font-weight: 600; color: #e67e22; margin-bottom: 30px;
  }

  .hero-banner {
    width: 85%; max-height: 260px; object-fit: cover; border-radius: 20px;
    margin-bottom: 30px;
    box-shadow: 0 8px 32px rgba(231,76,60,0.2);
    border: 3px solid rgba(255,255,255,0.6);
  }

  .event-title {
    font-size: 26pt; font-weight: 800; color: #c0392b;
    margin-bottom: 8px; line-height: 1.2;
  }

  .event-subtitle {
    font-size: 14pt; font-weight: 400; color: #8e44ad; margin-bottom: 24px;
  }

  .event-meta {
    display: flex; justify-content: center; gap: 28px; margin-bottom: 28px; flex-wrap: wrap;
  }

  .meta-item {
    background: white; padding: 10px 22px; border-radius: 14px;
    box-shadow: 0 2px 12px rgba(231,76,60,0.08); font-size: 10pt;
    border-left: 3px solid #e74c3c;
  }

  .meta-item strong { color: #e74c3c; display: block; font-size: 8pt; text-transform: uppercase; letter-spacing: 0.5px; }

  .coordinators-section { margin-top: 20px; width: 80%; }

  .coordinators-section h3 {
    font-size: 10pt; text-transform: uppercase; letter-spacing: 1px; color: #e67e22; margin-bottom: 10px;
  }

  .coord-grid { display: flex; justify-content: center; gap: 20px; flex-wrap: wrap; }

  .coord-item {
    background: white; padding: 8px 18px; border-radius: 12px;
    font-size: 9pt; box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    border-top: 2px solid #e74c3c;
  }

  .coord-item .label { font-size: 7pt; color: #e67e22; text-transform: uppercase; }
  .coord-item .name { font-weight: 600; color: #2d1b4e; }

  /* ===== CONTENT PAGES ===== */
  .section { margin-bottom: 28px; page-break-inside: avoid; }

  .section-heading {
    font-size: 16pt; font-weight: 700; color: #c0392b;
    border-left: 4px solid #e74c3c; padding-left: 14px;
    margin-bottom: 14px; padding-bottom: 4px;
    border-bottom: 2px solid #fde8e8;
  }

  .section-content p { text-align: justify; margin-bottom: 10px; color: #333; }
  .section-content ul { margin-left: 20px; margin-bottom: 12px; }
  .section-content ul li { margin-bottom: 6px; color: #333; }
  .section-content ul li::marker { color: #e74c3c; }

  /* ===== IMAGE LAYOUTS ===== */
  .image-container { margin: 16px 0; }
  .img-full { text-align: center; }
  .img-full img { width: 100%; max-height: 400px; object-fit: cover; border-radius: 14px; }
  .img-side-by-side { display: flex; gap: 12px; }
  .img-side-by-side img { flex: 1; width: 48%; height: 240px; object-fit: cover; border-radius: 14px; }
  .img-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(45%, 1fr)); gap: 12px; }
  .img-grid img { width: 100%; height: 200px; object-fit: cover; border-radius: 14px; }

  .frame-circle img { border-radius: 50%; aspect-ratio: 1; }
  .frame-oval img { border-radius: 50%; }
  .frame-rounded img { border-radius: 18px; }

  .img-caption { text-align: center; font-size: 8pt; color: #999; margin-top: 4px; font-style: italic; }

  /* ===== BUDGET TABLE ===== */
  .budget-table { width: 100%; border-collapse: collapse; margin: 14px 0; font-size: 10pt; }
  .budget-table th {
    background: linear-gradient(135deg, #e74c3c, #e67e22);
    color: white; padding: 10px 14px; text-align: left; font-weight: 600;
    font-size: 9pt; text-transform: uppercase; letter-spacing: 0.5px;
  }
  .budget-table td { padding: 9px 14px; border-bottom: 1px solid #fde8e8; }
  .budget-table tr:nth-child(even) { background: #fff5f5; }
  .budget-total { font-weight: 700; background: #fde8e8 !important; color: #c0392b; }

  /* ===== GALLERY ===== */
  .gallery-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin: 14px 0; }
  .gallery-grid img { width: 100%; height: 180px; object-fit: cover; border-radius: 14px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }

  @media print {
    .section { page-break-inside: avoid; }
    .front-page { page-break-after: always; }
  }
</style>
</head>
<body>

  <!-- FRONT PAGE -->
  <div class="front-page">
    <div class="logo-row">
      {{#if report.frontPage.collegeLogo}}<img src="{{report.frontPage.collegeLogo}}" alt="College">{{/if}}
      {{#if report.frontPage.departmentLogo}}<img src="{{report.frontPage.departmentLogo}}" alt="Department">{{/if}}
      {{#if report.frontPage.eventLogo}}<img src="{{report.frontPage.eventLogo}}" alt="Event">{{/if}}
    </div>

    <div class="institution-name">{{report.frontPage.institutionName}}</div>
    <div class="department-name">{{report.frontPage.departmentName}}</div>

    {{#if report.frontPage.heroBanner}}
      <img src="{{report.frontPage.heroBanner}}" class="hero-banner" alt="Event Banner">
    {{/if}}

    <div class="event-title">{{report.frontPage.eventTitle}}</div>
    {{#if report.frontPage.eventSubtitle}}
      <div class="event-subtitle">{{report.frontPage.eventSubtitle}}</div>
    {{/if}}

    <div class="event-meta">
      {{#if report.frontPage.venueDate}}
        <div class="meta-item"><strong>Date</strong>{{report.frontPage.venueDate}}</div>
      {{/if}}
      {{#if report.event.venue}}
        <div class="meta-item"><strong>Venue</strong>{{report.event.venue}}</div>
      {{/if}}
      {{#if report.event.department}}
        <div class="meta-item"><strong>Department</strong>{{report.event.department}}</div>
      {{/if}}
    </div>

    <div class="coordinators-section">
      <h3>Organized By</h3>
      <div class="coord-grid">
        {{#if report.event.convener}}<div class="coord-item"><div class="label">Convener</div><div class="name">{{report.event.convener}}</div></div>{{/if}}
        {{#if report.event.coConvener}}<div class="coord-item"><div class="label">Co-Convener</div><div class="name">{{report.event.coConvener}}</div></div>{{/if}}
        {{#if report.event.facultyCoordinator}}<div class="coord-item"><div class="label">Faculty Coordinator</div><div class="name">{{report.event.facultyCoordinator}}</div></div>{{/if}}
        {{#if report.event.studentCoordinator}}<div class="coord-item"><div class="label">Student Coordinator</div><div class="name">{{report.event.studentCoordinator}}</div></div>{{/if}}
      </div>
    </div>
  </div>

  <!-- CONTENT SECTIONS -->
  {{#each sections}}
    {{#unless (eq this.type "BUDGET")}}
      {{#unless (eq this.type "GALLERY")}}
        <div class="section">
          <h2 class="section-heading">{{this.heading}}</h2>
          <div class="section-content">
            {{#each this.content.paragraphs}}<p>{{this}}</p>{{/each}}
            {{#if this.content.bullets.length}}
              <ul>{{#each this.content.bullets}}<li>{{this}}</li>{{/each}}</ul>
            {{/if}}
            {{#if this.content.richText}}{{{this.content.richText}}}{{/if}}
          </div>
          {{#if this.images.length}}
            <div class="image-container {{imageGridClass this.imageCount}} frame-{{this.imageFrame}}">
              {{#each this.images}}
                <div><img src="{{this.url}}" alt="{{this.caption}}">{{#if this.caption}}<div class="img-caption">{{this.caption}}</div>{{/if}}</div>
              {{/each}}
            </div>
          {{/if}}
        </div>
      {{/unless}}
    {{/unless}}
  {{/each}}

  <!-- GALLERY SECTIONS -->
  {{#each sections}}
    {{#if (eq this.type "GALLERY")}}
      <div class="section">
        <h2 class="section-heading">{{this.heading}}</h2>
        <div class="gallery-grid">
          {{#each this.images}}<img src="{{this.url}}" alt="{{this.caption}}">{{/each}}
        </div>
      </div>
    {{/if}}
  {{/each}}

  <!-- BUDGET SECTION -->
  {{#if budgets.length}}
    <div class="section">
      <h2 class="section-heading">Budget Summary</h2>
      <table class="budget-table">
        <thead><tr><th>#</th><th>Item</th><th>Category</th><th>Qty</th><th>Unit Cost</th><th>Total</th></tr></thead>
        <tbody>
          {{#each budgets}}
            <tr><td>{{@index}}</td><td>{{this.item}}</td><td>{{this.category}}</td><td>{{this.quantity}}</td><td>{{formatCurrency this.unitCost}}</td><td>{{formatCurrency this.totalCost}}</td></tr>
          {{/each}}
          <tr class="budget-total"><td colspan="5" style="text-align:right;"><strong>Grand Total</strong></td><td><strong>{{formatCurrency budgetTotal}}</strong></td></tr>
        </tbody>
      </table>
    </div>
  {{/if}}

  <div style="text-align:center;margin-top:40px;padding:20px;border-top:2px solid #fde8e8;font-size:8pt;color:#999;">
    Report generated on {{generatedAt}} | Smart Event Report System
  </div>

</body>
</html>
