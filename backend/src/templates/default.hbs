<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Inter', -apple-system, sans-serif;
    color: #1e293b;
    line-height: 1.7;
    font-size: 11pt;
    background: #f8fafc;
  }

  /* ===== FRONT PAGE ===== */
  .front-page {
    page-break-after: always;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: linear-gradient(135deg, #1e3a5f 0%, #2563eb 50%, #3b82f6 100%);
    padding: 40px 50px;
  }

  .logo-top-row {
    display: flex; align-items: center; justify-content: center;
    gap: 24px; margin-bottom: 24px; width: 100%;
  }

  .logo-top-row img { object-fit: contain; border-radius: 10px; background: white; padding: 6px; }

  .main-event-logo { text-align: center; margin-bottom: 20px; }
  .main-event-logo img { max-width: 260px; max-height: 180px; object-fit: contain; border-radius: 14px; background: white; padding: 10px; }

  .institution-name { font-size: 16pt; font-weight: 800; color: white; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 4px; }
  .department-name { font-size: 12pt; font-weight: 500; color: rgba(255,255,255,0.8); margin-bottom: 24px; }

  .event-title { font-size: 22pt; font-weight: 800; color: white; margin-bottom: 6px; line-height: 1.2; }
  .event-subtitle { font-size: 13pt; font-weight: 400; color: rgba(255,255,255,0.8); margin-bottom: 24px; }

  .details-table {
    width: 85%; border-collapse: collapse; margin: 20px auto;
    background: white; border-radius: 14px; overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
  }
  .details-table td { padding: 10px 18px; font-size: 10pt; border-bottom: 1px solid #e2e8f0; }
  .details-table tr:last-child td { border-bottom: none; }
  .detail-key { font-weight: 700; color: #1e40af; width: 35%; background: #eff6ff; }
  .detail-value { color: #333; }

  /* ===== CONTENT ===== */
  .content-card {
    background: white; border-radius: 16px; padding: 22px 26px;
    margin: 14px 24px; box-shadow: 0 1px 6px rgba(0,0,0,0.06);
    page-break-inside: avoid;
  }

  .section-heading { font-size: 14pt; font-weight: 700; color: #1e40af; margin-bottom: 12px; padding-bottom: 6px; border-bottom: 2px solid #dbeafe; }
  .section-content p { text-align: justify; margin-bottom: 10px; color: #334155; }
  .section-content ul { margin-left: 20px; margin-bottom: 12px; }
  .section-content ul li { margin-bottom: 6px; color: #334155; }
  .section-content ul li::marker { color: #2563eb; }

  .image-rectangle { background: white; border-radius: 12px; padding: 10px; margin: 12px 24px; box-shadow: 0 1px 6px rgba(0,0,0,0.06); text-align: center; page-break-inside: avoid; }
  .image-rectangle img { width: 100%; max-height: 400px; object-fit: cover; border-radius: 8px; }
  .img-caption { text-align: center; font-size: 8pt; color: #94a3b8; margin-top: 4px; font-style: italic; }

  /* ===== IMAGE GRID LAYOUTS (in sections) ===== */
  .section-grid {
    display: block;
  }
  .section-grid.has-images {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 20px;
    align-items: start;
  }
  .section-text { flex: 1; }
  .section-photos { flex: 1; }
  .image-container { display: grid; gap: 12px; width: 100%; }
  .img-full { grid-template-columns: 1fr; }
  .img-full img { width: 100%; max-height: 320px; object-fit: cover; border-radius: 10px; }
  .img-side-by-side { grid-template-columns: 1fr 1fr; }
  .img-side-by-side img { width: 100%; height: 160px; object-fit: cover; border-radius: 10px; }
  .img-grid { grid-template-columns: 1fr 1fr; }
  .img-grid img { width: 100%; height: 120px; object-fit: cover; border-radius: 10px; }
  .image-wrapper { position: relative; }

  .budget-table { width: 100%; border-collapse: collapse; margin: 14px 0; font-size: 10pt; }
  .budget-table th { background: #1e40af; color: white; padding: 10px 14px; text-align: left; font-weight: 600; font-size: 9pt; text-transform: uppercase; }
  .budget-table td { padding: 9px 14px; border-bottom: 1px solid #e2e8f0; }
  .budget-table tr:nth-child(even) { background: #f8fafc; }
  .budget-total { font-weight: 700; background: #eff6ff !important; color: #1e40af; }

  .gallery-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin: 14px 0; }
  .gallery-grid img { width: 100%; height: 180px; object-fit: cover; border-radius: 10px; }

  @media print { .content-card { page-break-inside: avoid; } .front-page { page-break-after: always; } }
</style>
</head>
<body>

  <div class="front-page">
    {{#if report.frontPage.logos.length}}
      <div class="logo-top-row">
        {{#each report.frontPage.logos}}
          {{#unless @last}}
            <img src="{{this}}" alt="Logo" style="width: {{logoSize ../report.frontPage.logos.length}}px; height: {{logoSize ../report.frontPage.logos.length}}px;">
          {{/unless}}
        {{/each}}
      </div>
    {{/if}}

    {{#if report.frontPage.institutionName}}<div class="institution-name">{{report.frontPage.institutionName}}</div>{{/if}}
    {{#if report.frontPage.departmentName}}<div class="department-name">{{report.frontPage.departmentName}}</div>{{/if}}

    {{#if report.frontPage.logos.length}}
      <div class="main-event-logo"><img src="{{lastLogo report.frontPage.logos}}" alt="Event Logo"></div>
    {{/if}}

    <div class="event-title">{{report.frontPage.eventTitle}}</div>
    {{#if report.frontPage.eventSubtitle}}<div class="event-subtitle">{{report.frontPage.eventSubtitle}}</div>{{/if}}

    {{#if report.frontPage.eventDetails.length}}
      <table class="details-table">
        {{#each report.frontPage.eventDetails}}<tr><td class="detail-key">{{this.key}}</td><td class="detail-value">{{this.value}}</td></tr>{{/each}}
      </table>
    {{/if}}
  </div>

  {{#each sections}}
    {{#unless (eq this.type "BUDGET")}}{{#unless (eq this.type "GALLERY")}}
      <div class="content-card">
        <h2 class="section-heading">{{this.heading}}</h2>
        <div class="section-grid {{#if this.images.length}}has-images{{/if}}">
          <div class="section-text">
            <div class="section-content">
              {{#each this.content.paragraphs}}<p>{{this}}</p>{{/each}}
              {{#if this.content.bullets.length}}<ul>{{#each this.content.bullets}}<li>{{this}}</li>{{/each}}</ul>{{/if}}
              {{#if this.content.richText}}{{{this.content.richText}}}{{/if}}
            </div>
          </div>
          {{#if this.images.length}}
            <div class="section-photos">
              <div class="image-container {{imageGridClass this.imageCount}}">
                {{#each this.images}}
                  <div class="image-wrapper">
                    <img src="{{this.url}}" alt="{{this.caption}}">
                    {{#if this.caption}}<div class="img-caption">{{this.caption}}</div>{{/if}}
                  </div>
                {{/each}}
              </div>
            </div>
          {{/if}}
        </div>
      </div>
    {{/unless}}{{/unless}}
  {{/each}}

  {{#each sections}}
    {{#if (eq this.type "GALLERY")}}
      <div class="content-card"><h2 class="section-heading">{{this.heading}}</h2></div>
      {{#each this.images}}<div class="image-rectangle"><img src="{{this.url}}" alt="{{this.caption}}">{{#if this.caption}}<div class="img-caption">{{this.caption}}</div>{{/if}}</div>{{/each}}
    {{/if}}
  {{/each}}

  {{#if budgets.length}}
    <div class="content-card">
      <h2 class="section-heading">Budget Summary</h2>
      <table class="budget-table">
        <thead><tr><th>#</th><th>Item</th><th>Category</th><th>Qty</th><th>Unit Cost</th><th>Total</th></tr></thead>
        <tbody>
          {{#each budgets}}<tr><td>{{@index}}</td><td>{{this.item}}</td><td>{{this.category}}</td><td>{{this.quantity}}</td><td>{{formatCurrency this.unitCost}}</td><td>{{formatCurrency this.totalCost}}</td></tr>{{/each}}
          <tr class="budget-total"><td colspan="5" style="text-align:right;"><strong>Grand Total</strong></td><td><strong>{{formatCurrency budgetTotal}}</strong></td></tr>
        </tbody>
      </table>
    </div>
  {{/if}}

  <div style="text-align:center;margin-top:40px;padding:20px;border-top:2px solid #e2e8f0;font-size:8pt;color:#94a3b8;">
    Report generated on {{generatedAt}} | Smart Event Report System
  </div>

</body>
</html>
